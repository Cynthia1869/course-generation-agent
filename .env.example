APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
FRONTEND_ORIGIN=http://localhost:5173
CORS_ALLOW_ORIGIN_REGEX=https?://(localhost|127\\.0\\.0\\.1|0\\.0\\.0\\.0|192\\.168\\.\\d+\\.\\d+|10\\.\\d+\\.\\d+\\.\\d+)(:\\d+)?$
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/course_agent
DEEPSEEK_CONFIG_FILE=config/deepseek.yaml
MAX_AUTO_OPTIMIZATION_LOOPS=2
# 把真实 key 放到 .env.local，不要写在这个文件里
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEFAULT_REVIEW_THRESHOLD=8.0
