{
  "compilerOptions": {
    "baseUrl": "../../frontend",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "typeRoots": ["../../frontend/node_modules/@types"],
    "types": ["node"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true
  },
  "include": [
    "../../frontend/src/**/*.ts",
    "../../frontend/src/**/*.vue",
    "../../frontend/src/**/*.d.ts"
  ]
}
